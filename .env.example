# IBM Watsonx.ai Configuration
IBM_WATSONX_API_KEY=
IBM_WATSONX_PROJECT_ID=
IBM_WATSONX_URL=
IBM_GRANITE_MODEL_ID=

# Vector Database
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=farming_knowledge

# Weather API (free, no key needed)
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1

# Mandi Price API (optional)
MANDI_API_KEY=
MANDI_API_BASE_URL=https://api.data.gov.in/resource/9ef84268-d588-465a-a308-a864a43d0070

# App
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
LOG_LEVEL=INFO

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
